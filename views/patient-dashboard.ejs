<%- include('partials/header') %>

<section class="section">
  <div class="container">
    <div class="page-hero" style="padding-top:0; text-align:left;">
      <span class="eyebrow">My Account</span>
      <h1>Hi <%= patient.first_name %>, here&rsquo;s your appointment history</h1>
    </div>

    <% if (typeof booked !== 'undefined' && booked) { %><div class="banner banner-success">Your appointment has been booked successfully.</div><% } %>

    <div style="margin-bottom:2rem;">
      <a href="/book-appointment" class="btn btn-primary">Book another appointment</a>
    </div>

    <h2>Upcoming appointments</h2>
    <% if (upcoming.length === 0) { %>
      <div class="empty-state">You have no upcoming appointments. <a href="/book-appointment">Book one now.</a></div>
    <% } else { %>
      <div class="table-wrap">
        <table class="report-table">
          <thead><tr><th>Date</th><th>Time</th><th>Service</th><th>Dentist</th><th>Status</th><th></th></tr></thead>
          <tbody>
            <% upcoming.forEach(a => { %>
              <tr>
                <td><%= a.appointment_date %></td>
                <td><%= a.appointment_time %></td>
                <td><%= a.service_name %></td>
                <td><%= a.dentist_title %> <%= a.dentist_name %></td>
                <td><span class="status-pill status-<%= a.status %>"><%= a.status %></span></td>
                <td>
                  <button 
                    class="btn btn-ghost btn-sm cancel-trigger" 
                    data-id="<%= a.id %>" 
                    data-date="<%= a.appointment_date %>" 
                    data-time="<%= a.appointment_time %>"
                    type="button">
                    Cancel
                  </button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

    <h2 style="margin-top:2.5rem;">Past appointments</h2>
    <% if (past.length === 0) { %>
      <div class="empty-state">No past appointments yet.</div>
    <% } else { %>
      <div class="table-wrap">
        <table class="report-table">
          <thead><tr><th>Date</th><th>Time</th><th>Service</th><th>Dentist</th><th>Status</th></tr></thead>
          <tbody>
            <% past.forEach(a => { %>
              <tr>
                <td><%= a.appointment_date %></td>
                <td><%= a.appointment_time %></td>
                <td><%= a.service_name %></td>
                <td><%= a.dentist_title %> <%= a.dentist_name %></td>
                <td><span class="status-pill status-<%= a.status %>"><%= a.status %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</section>

<!-- Cancel Appointment Confirmation Modal -->
<div id="cancel-modal" class="modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="modal-title" hidden>
  <div class="modal-content">
    <div class="modal-header">
      <h3 id="modal-title">Cancel Appointment</h3>
    </div>
    <div class="modal-body">
      <p>Are you sure you want to cancel your appointment on <strong id="cancel-modal-date"></strong> at <strong id="cancel-modal-time"></strong>?</p>
      <p style="font-size: 0.85rem; color: var(--color-error); margin-top: 0.5rem;">This action cannot be undone.</p>
    </div>
    <div class="modal-footer">
      <button type="button" class="btn btn-ghost btn-sm" id="close-modal-btn">Keep Appointment</button>
      <form id="cancel-modal-form" method="POST" action="">
        <button type="submit" class="btn btn-primary btn-sm" style="background: var(--color-error); border-color: var(--color-error);">Yes, Cancel</button>
      </form>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const modal = document.getElementById('cancel-modal');
  const modalForm = document.getElementById('cancel-modal-form');
  const modalDate = document.getElementById('cancel-modal-date');
  const modalTime = document.getElementById('cancel-modal-time');
  const closeModalBtn = document.getElementById('close-modal-btn');
  const triggers = document.querySelectorAll('.cancel-trigger');

  triggers.forEach(button => {
    button.addEventListener('click', () => {
      const apptId = button.dataset.id;
      const date = button.dataset.date;
      const time = button.dataset.time;

      modalForm.action = `/appointments/${apptId}/cancel`;
      modalDate.textContent = date;
      modalTime.textContent = time;

      modal.removeAttribute('hidden');
      requestAnimationFrame(() => modal.classList.add('is-open'));
    });
  });

  function closeModal() {
    modal.classList.remove('is-open');
    modal.setAttribute('hidden', '');
  }

  closeModalBtn.addEventListener('click', closeModal);
  
  // Close on backdrop click
  modal.addEventListener('click', (e) => {
    if (e.target === modal) {
      closeModal();
    }
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal.classList.contains('is-open')) {
      closeModal();
    }
  });
});
</script>

<%- include('partials/footer') %>

