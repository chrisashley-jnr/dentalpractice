<%- include('../partials/header') %>

<section class="section">
  <div class="container">
    <div class="page-hero" style="padding-top:0; text-align:left;">
      <span class="eyebrow">Staff Report</span>
      <h1>Contact enquiries</h1>
      <p><a href="/staff/dashboard">&larr; Back to dashboard</a></p>
    </div>

    <% if (enquiries.length === 0) { %>
      <div class="empty-state">No enquiries submitted yet.</div>
    <% } else { %>
      <div class="table-wrap">
        <table class="report-table">
          <thead><tr><th>Date</th><th>Name</th><th>Email</th><th>Message</th></tr></thead>
          <tbody>
            <% enquiries.forEach(e => { %>
              <tr>
                <td><%= e.submitted_at.slice(0,16).replace('T',' ') %></td>
                <td><%= e.name %></td>
                <td><%= e.email %></td>
                <td><%= e.message %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>
